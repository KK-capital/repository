<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- .NET 10 類別庫：Application 層，依賴 Domain 與 QuickFIX/n -->
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>FakeFIXGateway.Application</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\FakeFIXGateway.Domain\FakeFIXGateway.Domain.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- QuickFIX/n FIX 協議實作庫 -->
    <PackageReference Include="QuickFIXn" Version="1.12.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
  </ItemGroup>

</Project>
